{
  "name": "aeogeo",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "docker compose up --build",
    "dev:full": "docker compose --profile temporal up --build",
    "dev:api": "cd packages/api && uv run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:web": "cd packages/web && bun run dev",
    "lint": "cd packages/web && bun run lint",
    "typecheck": "cd packages/web && bun run typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
