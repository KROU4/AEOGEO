# ========================
# DATABASE
# ========================
# URL подключения к PostgreSQL через asyncpg (обязательно)
# Формат: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://aeogeo:localdev@localhost:5432/aeogeo

# Пользователь PostgreSQL (используется в docker-compose)
POSTGRES_USER=aeogeo

# Пароль PostgreSQL (используется в docker-compose)
POSTGRES_PASSWORD=localdev

# Имя базы данных PostgreSQL (используется в docker-compose)
POSTGRES_DB=aeogeo

# ========================
# REDIS
# ========================
# URL подключения к Redis (обязательно)
# Используется для кэширования и rate limiting
REDIS_URL=redis://localhost:6379

# ========================
# SECURITY
# ========================
# Секретный ключ приложения для подписи JWT и других криптографических операций (обязательно)
SECRET_KEY=YOUR_SECRET_KEY

# Ключ шифрования Fernet для хранения API-ключей провайдеров в зашифрованном виде (обязательно для работы с AI-ключами)
# Сгенерировать: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
ENCRYPTION_KEY=YOUR_FERNET_KEY

# ========================
# AUTH (Clerk)
# ========================
# Публичный ключ Clerk (обязательно для аутентификации)
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY

# Секретный ключ Clerk (обязательно для верификации токенов на бэкенде)
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY

# URL фронтенд API Clerk (опционально, автоматически определяется из publishable key)
CLERK_FRONTEND_API_URL=

# URL для редиректа после принятия приглашения в команду (опционально)
CLERK_INVITATION_REDIRECT_URL=https://sand-source.com/accept-invite

# ========================
# AI PROVIDERS — API KEYS
# ========================
# API-ключ OpenAI для генерации embeddings (text-embedding-3-large) и работы ChatGPT engine (обязательно для pipeline)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# API-ключ OpenRouter для доступа к Perplexity, Copilot и другим провайдерам (опционально)
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY

# API-ключ Tavily для поиска и краулинга (опционально)
TAVILY_API_KEY=YOUR_TAVILY_API_KEY

# ========================
# CORS
# ========================
# Разрешённые origin для CORS, через запятую (обязательно)
CORS_ORIGINS=http://localhost:5173

# ========================
# APPLICATION
# ========================
# Режим отладки — включает echo SQL-запросов и расширенное логирование (опционально, по умолчанию false)
DEBUG=true

# ========================
# TEMPORAL (Workflow Engine)
# ========================
# Адрес сервера Temporal (опционально, по умолчанию temporal:7233)
TEMPORAL_HOST=temporal:7233

# ========================
# FRONTEND (Vite)
# ========================
# URL API для фронтенда (обязательно для web-приложения)
VITE_API_URL=http://localhost:8000

# Имя приложения (опционально)
VITE_APP_NAME=AEOGEO

# Публичный ключ Clerk для фронтенда (обязательно — без него дашборд не рендерится)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY

