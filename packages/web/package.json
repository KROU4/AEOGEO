    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@tanstack/query-sync-storage-persister": "^5.95.2",
    "@tanstack/react-query": "^5.60.0",
    "@tanstack/react-query-persist-client": "^5.95.2",
    "@tanstack/react-router": "^1.90.0",
