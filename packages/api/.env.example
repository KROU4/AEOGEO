DATABASE_URL=postgresql+asyncpg://aeogeo:localdev@localhost:5432/aeogeo
REDIS_URL=redis://localhost:6379
SECRET_KEY=change-me-in-production
# Список через запятую, без пробелов вокруг URL. Прод: https://ваш-фронт.up.railway.app
# Comma-separated; no trailing slash (must match browser Origin exactly).
CORS_ORIGINS=http://localhost:5173
# Optional: e.g. https://.*\.up\.railway\.app  (escape backslashes in env files if needed)
# CORS_ORIGIN_REGEX=
DEBUG=true
ENCRYPTION_KEY=
TAVILY_API_KEY=
# LLM keys — only via env on the API server (not stored in DB / UI)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_FRONTEND_API_URL=
CLERK_INVITATION_REDIRECT_URL=http://localhost:5173/accept-invite
CLERK_WEBHOOK_SECRET=
# Stakeholder demo only: auto-create tenant+user on first Clerk request (no /complete-signup). Never enable in production.
# DEMO_MODE=true
# DEMO_DEFAULT_COMPANY_NAME=Demo
# Optional: path to cloned https://github.com/zubair-trabzada/geo-seo-claude (uses scripts/*.py)
GEO_SEO_CLAUDE_HOME=
