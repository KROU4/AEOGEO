# Скопируйте в `.env` в корне репозитория — Docker Compose подставляет эти переменные
# при разборе docker-compose.yml (подстановка ${VAR}).

POSTGRES_USER=aeogeo
POSTGRES_PASSWORD=localdev
POSTGRES_DB=aeogeo
POSTGRES_PORT=5432

REDIS_PORT=6379

API_PORT=8000
WEB_PORT=5173
TEMPORAL_GRPC_PORT=7233
TEMPORAL_UI_PORT=8233

# URL API для Vite в браузере (с хоста машины, не имени контейнера)
VITE_API_URL=http://localhost:8000

CORS_ORIGINS=http://localhost:5173

# Не задавайте DATABASE_URL здесь, если в packages/api/.env стоит localhost —
# сервис `api` в compose задаёт DATABASE_URL на хост `db` через секцию environment.
