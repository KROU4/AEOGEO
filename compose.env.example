# Скопируйте в `.env` в корне репозитория — Docker Compose подставляет эти переменные
# при разборе docker-compose.yml (подстановка ${VAR}).

POSTGRES_USER=aeogeo
POSTGRES_PASSWORD=localdev
POSTGRES_DB=aeogeo
POSTGRES_PORT=5432

REDIS_PORT=6379

API_PORT=8000
WEB_PORT=5173
TEMPORAL_GRPC_PORT=7233
TEMPORAL_UI_PORT=8233
# Образ UI (при ошибке pull смените на тег с https://hub.docker.com/r/temporalio/ui/tags )
# TEMPORAL_UI_IMAGE=temporalio/ui:2.48.2

# URL API для Vite в браузере (с хоста машины, не имени контейнера).
# По умолчанию подставляется http://localhost:${API_PORT}
VITE_API_URL=http://localhost:8000

# Браузерный origin фронта (для CORS). По умолчанию совпадает с WEB_PORT.
CORS_ORIGINS=http://localhost:5173

# Hot reload в Docker: опрос файловой системы (нужно на Docker Desktop Windows/macOS).
# На Linux с нативным bind-mount можно поставить false, чтобы снизить нагрузку на CPU.
DEV_WATCH_POLLING=true
CHOKIDAR_INTERVAL=1000

# Не задавайте DATABASE_URL / REDIS_URL в этом файле для доступа к БД из контейнеров —
# compose задаёт их на сервисы `db` и `redis`. Переменная DATABASE_URL в корневом .env
# не должна подменять URL внутри compose (используются POSTGRES_* и фиксированные хосты).

# --- Быстрее сборка / старт (см. docker-compose.yml) ---
# Сборка API без Crawl4AI + Chromium (по умолчанию в compose = 0). Для прода / краула: INSTALL_CRAWL=1
# INSTALL_CRAWL=0
# Пропуск alembic при старте api (только dev; схема может отставать): SKIP_ALEMBIC=1

# Полный стек с Temporal: docker compose --profile temporal up --build
